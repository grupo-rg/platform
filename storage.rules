rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // General safety measure: Nothing completely public by default
      allow read, write: if false;
    }

    // Public Assets: Next.js or Browser viewing images
    match /dream-renovator/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // AI Generated Renders and Originals
    match /renders/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Budget Multimedia: allow user to upload PDF / Jpegs (< 10 MB)
    match /budget-multimedia/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('application/pdf'));
    }

    // Simple Uploads — restringido a image/* y application/pdf para
    // evitar que se suba .html con XSS, .exe, scripts, etc.
    match /uploads/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('application/pdf')
                   );
    }

    // Public uploads: imágenes y PDFs subidos desde formularios públicos
    // y desde el chat público (foto de la estancia, plano, etc.).
    // Server-side (Admin SDK) los persiste bajo public_uploads/leads/<email>/...
    // y public_uploads/chat-<userId>/... Cliente-side los persiste en raíz.
    match /public_uploads/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('application/pdf')
                   );
    }

    // Admin Base rules: el price book sólo lo gestionan administradores
    // autenticados con custom claim `admin == true`. Lectura idem — el
    // catálogo de precios es información comercial sensible.
    match /admin/price-books/{allPaths=**} {
       allow read: if request.auth != null && request.auth.token.admin == true;
       allow write: if request.auth != null
                    && request.auth.token.admin == true
                    && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
