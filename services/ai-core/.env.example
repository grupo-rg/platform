# Google Cloud / Firebase Admin Auth 
# Using explicit string variables as configured in Next.js (admin-app.ts)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="your-service-account@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR\\nKEY\\nHERE\\n-----END PRIVATE KEY-----\\n"

# Google Generative AI (Gemini)
GOOGLE_GENAI_API_KEY="your-gemini-api-key-here"

# Qdrant Vector Database
QDRANT_URL="https://your-cluster-url.qdrant.tech"
QDRANT_API_KEY="your-qdrant-api-key-here"
